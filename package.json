{
  "name": "intake-zero",
  "version": "0.1.0",
  "private": true,
  "description": "Claude-backed prospect intake for ZeroIndex, orchestrated with Vercel Workflow DevKit.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "eval": "tsx evals/run.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=.env.local src/db/migrate.ts",
    "db:migrate:prod": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@libsql/client": "^0.17.3",
    "@opentelemetry/api": "^1.9.0",
    "@react-email/render": "^2.0.8",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "resend": "^6.12.3",
    "undici": "^6.25.0",
    "workflow": "^4.2.4",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19",
    "@zeroindex-ai/eval-pack": "^0.3.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^6",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "overrides": {
      "devalue@<5.6.4": ">=5.6.4",
      "undici@>=7.0.0 <7.24.0": ">=7.24.0 <8",
      "postcss@<8.5.10": ">=8.5.10",
      "esbuild@<0.25.0": ">=0.25.0"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.0.0"
}
