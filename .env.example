# Turso libsql — provisioned per the deploy-zeroindex-vercel-app skill.
TURSO_DATABASE_URL=libsql://intake-zero-<org>.turso.io
TURSO_AUTH_TOKEN=

# Anthropic — used by the classify + draft steps. Stored in 1Password.
ANTHROPIC_API_KEY=

# Resend — used by notify-owner + ack-prospect steps. Stored in 1Password.
RESEND_API_KEY=
FROM_EMAIL=intake@zeroindex.ai
OWNER_EMAIL=hello@zeroindex.ai

# Admin sign-in (single shared secret for v0.1; rotate before any new env).
# Generate with: openssl rand -base64 48
ADMIN_TOKEN=

# Used by run-status page metadata + email links.
PUBLIC_BASE_URL=https://intake.zeroindex.ai
